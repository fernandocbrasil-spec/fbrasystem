# =============================================================================
# PF Advogados ERP — Production Environment Variables
# Copy to .env.production.local (never commit real values)
# =============================================================================

# --- Auth (REQUIRED) ---
AUTH_SECRET=                          # openssl rand -base64 32
NEXTAUTH_URL=https://erp.pfadvogados.com.br

# --- Azure AD / Microsoft Entra ID (REQUIRED for production) ---
AZURE_AD_CLIENT_ID=                   # Azure Portal → App registrations → Application (client) ID
AZURE_AD_CLIENT_SECRET=               # Azure Portal → Certificates & secrets
AZURE_AD_TENANT_ID=                   # Azure Portal → Directory (tenant) ID

# --- Role Mapping (optional, override defaults) ---
# JSON: {"email": "role"} — default roles: socio, advogado, financeiro, admin
# Default: fernando@pfadvogados.com.br=socio, joserafa@pfadvogados.com.br=socio
# AZURE_ROLE_MAP={"maria@pfadvogados.com.br":"financeiro"}

# --- Database (REQUIRED) ---
DATABASE_URL=                         # postgresql://user:pass@host:5432/db?sslmode=require

# --- External Integrations (stubs for now) ---
NFSE_ADAPTER=stub                     # stub | focus
GDRIVE_ADAPTER=stub                   # stub | real
AI_ADAPTER=stub                       # stub | openai

# --- Monitoring (recommended) ---
# SENTRY_DSN=                         # Sentry project DSN
# SENTRY_ORG=                         # Sentry organization slug
# SENTRY_PROJECT=                     # Sentry project slug

# --- Node ---
NODE_ENV=production
